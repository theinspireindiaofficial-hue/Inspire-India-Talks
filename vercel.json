{
  "functions": {
    "api/*.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/events/:slug",
      "destination": "/api/event?slug=:slug"
    },
    {
      "source": "/personality/:id",
      "destination": "/api/personality?id=:id"
    },
    {
      "source": "/business-insights/:id",
      "destination": "/api/business-insight?id=:id"
    },
    {
      "source": "/founders-talk",
      "destination": "/api/founders-talk"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}