# Newsletter — server-side env vars (set these in the Vercel dashboard, not in the repo)

# Mailchimp — primary. Account > Extras > API keys; Audience > Settings > Audience ID.
# The "-usXX" suffix on the API key is the data center (server prefix).
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
MAILCHIMP_AUDIENCE_ID=your_audience_id
# Optional; only set if it can't be derived from the API key suffix.
# MAILCHIMP_SERVER_PREFIX=us21

# Supabase — best-effort backup copy of the subscriber list (optional).
SUPABASE_URL=https://nsgmimfdttpdpwjxbliy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Site origin
PUBLIC_SITE_ORIGIN=https://www.inspireindiatalks.com
