# Newsletter — server-side env vars (set these in the Vercel dashboard, not in the repo)

# Supabase (Project Settings -> API of the inspire-india-talks project)
SUPABASE_URL=https://nsgmimfdttpdpwjxbliy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Site origin used to build confirmation / unsubscribe links
PUBLIC_SITE_ORIGIN=https://www.inspireindiatalks.com

# Email sending (Resend). Keep ENABLED=false until the key + domain are ready.
NEWSLETTER_EMAIL_ENABLED=false
RESEND_API_KEY=re_your_key_here
NEWSLETTER_FROM_EMAIL=Inspire India Talks <news@inspireindiatalks.com>
